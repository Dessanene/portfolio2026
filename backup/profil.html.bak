    <!-- Contenu principal -->
    <main class="profile-container">
            <!-- Section principale du profil - Carte unifiée avec fond animé -->
            <div class="unified-card">
                <!-- Photo et informations de base -->
                <div class="profile-header">
                    <div class="profile-photo">
                        <img src="img/profile-photo.jpg" alt="Dessanène Sanhan" onerror="this.src='https://via.placeholder.com/200x200?text=DS'">
                    </div>
                    <div class="profile-info">
                        <h2 class="profile-name">Déssanène Olivier SANHAN</h2>
                        <p class="profile-title">Étudiant en BTS SIO option SISR</p>
                        <p class="profile-subtitle">Solutions d'Infrastructure, Systèmes et Réseaux</p>
                        <div class="action-buttons">
                            <a href="#" class="action-button">
                                <i class="fas fa-eye"></i> Consulter CV
                            </a>
                            <a href="#" class="action-button primary">
                                <i class="fas fa-download"></i> Télécharger CV
                            </a>
                        </div>
                        <div class="profile-social">
                            <a href="https://www.linkedin.com/in/dessanène-olivier-sanhan-ba5174205/" target="_blank" class="social-icon">
                                <i class="fab fa-linkedin"></i>
                            </a>
                            <a href="mailto:oliviersanhan2016@gmail.com" class="social-icon">
                                <i class="fas fa-envelope"></i>
                            </a>
                            <a href="#" class="social-icon">
                                <i class="fab fa-github"></i>
                            </a>
                        </div>
                    </div>
                </div>
                
                <!-- Navigation par onglets - Version simplifiée -->
                <div class="profile-tabs">
                    <div class="profile-tab active" data-tab="about">
                        <i class="fas fa-user-circle"></i> À propos
                    </div>
                    <div class="profile-tab" data-tab="skills">
                        <i class="fas fa-laptop-code"></i> Compétences
                    </div>
                    <div class="profile-tab" data-tab="education">
                        <i class="fas fa-graduation-cap"></i> Formation
                    </div>
                    <div class="profile-tab" data-tab="qualities">
                        <i class="fas fa-star"></i> Qualités
                    </div>
                </div>

                <!-- Contenus des onglets -->
                <div class="tab-content active" id="about-content">
                    <section class="profile-section">
                        <h3 class="section-title"><i class="fas fa-user-circle"></i> À propos de moi</h3>
                        <div class="section-content">
                            <p class="about-text">Je m'appelle Déssanène sanhan Olivier sanhan et je suis passionné par les infrastructures réseau, la cybersécurité et l'administration système. Je suis actuellement en formation BTS Services Informatiques aux Organisations, spécialité Solutions d'Infrastructure, Systèmes et Réseaux (SISR).</p>
                            <p class="about-text">Mon objectif est de devenir administrateur systèmes et réseaux ou spécialiste en cybersécurité. Je m'intéresse particulièrement à la mise en place d'infrastructures sécurisées.</p>
                            <style>
                                .about-text::after {
                                    content: none !important;
                                    display: none !important;
                                }
                                #about-content .section-content::after {
                                    content: none !important;
                                    display: none !important;
                                }
                            </style>
                        </div>
                    </section>
                </div>

                <!-- Compétences -->
                <div class="tab-content" id="skills-content">
                    <section class="profile-section">
                        <h3 class="section-title"><i class="fas fa-laptop-code"></i> Compétences techniques</h3>
                        <div class="section-content">
                            <div class="skills-categories">
                                <div class="skill-category-card">
                                    <h3><i class="fas fa-code"></i> Programmation</h3>
                                    <div class="skill-bars">
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="90%">HTML/CSS</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 90%"></div>
                                            </div>
                                        </div>
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="60%">JavaScript</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 60%"></div>
                                            </div>
                                        </div>
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="50%">PHP</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 50%"></div>
                                            </div>
                                        </div>
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="65%">SQL</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 65%"></div>
                                            </div>
                                        </div>
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="55%">Bash</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 55%"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="skill-category-card">
                                    <h3><i class="fas fa-network-wired"></i> Systèmes et Réseaux</h3>
                                    <div class="skill-bars">
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="85%">Windows Server</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 85%"></div>
                                            </div>
                                        </div>
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="75%">Linux</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 75%"></div>
                                            </div>
                                        </div>
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="80%">Configuration réseau</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 80%"></div>
                                            </div>
                                        </div>
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="70%">Protocoles réseaux</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 70%"></div>
                                            </div>
                                        </div>
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="65%">Analyse de trames</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 65%"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="skill-category-card">
                                    <h3><i class="fas fa-shield-alt"></i> Cybersécurité</h3>
