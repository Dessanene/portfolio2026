                <div class="logo">
                    <a href="index.html">DS</a>
                </div>
                
                <div class="nav-links">
                    <!-- Liens principaux -->
                    <a href="index.html" class="nav-link">
                        <i class="fas fa-home"></i>
                        <span>Accueil</span>
                    </a>
                    <a href="bts-sio.html" class="nav-link">
                        <i class="fas fa-graduation-cap"></i>
                        <span>BTS SIO</span>
                    </a>
                    <a href="profil.html" class="nav-link active">
                        <i class="fas fa-user"></i>
                        <span>Profil</span>
                    </a>
                    
                    <!-- Menu Plus -->
                    <div class="plus-menu">
                        <a href="#" class="nav-link plus-toggle">
                            <i class="fas fa-plus-circle"></i>
                            <span>Plus</span>
                            <i class="fas fa-chevron-up plus-icon"></i>
                        </a>
                    </div>
                </div>
                
                <!-- Bouton menu mobile -->
                <div class="menu-toggle">
                    <span></span>
                    <span></span>
                    <span></span>
