                <!-- Formation -->
                <div class="tab-content" id="education-content">
                    <section class="profile-section">
                        <h3 class="section-title"><i class="fas fa-graduation-cap"></i> Formation</h3>
                        <div class="section-content">
                            <div class="timeline">
                                <div class="timeline-item">
                                    <div class="timeline-dot"></div>
                                    <div class="timeline-date">2022 - 2024</div>
                                    <div class="timeline-content">
                                        <h4>BTS SIO option SISR</h4>
                                        <p>Lycée Turgot, Paris</p>
                                        <p>Formation en cours sur les services informatiques aux organisations avec spécialisation en solutions d'infrastructure, systèmes et réseaux.</p>
                                        <ul>
                                            <li>Administration des systèmes et réseaux</li>
                                            <li>Sécurité des infrastructures</li>
                                            <li>Virtualisation et services cloud</li>
                                            <li>Supervision et maintenance</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="timeline-item">
                                    <div class="timeline-dot"></div>
                                    <div class="timeline-date">2021 - 2022</div>
                                    <div class="timeline-content">
                                        <h4>Baccalauréat Général</h4>
                                        <p>Lycée XXX, Paris</p>
                                        <p>Spécialités Mathématiques et Numérique et Sciences Informatiques.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <!-- Qualités -->
                <div class="tab-content" id="qualities-content">
                    <section class="profile-section">
                        <h3 class="section-title"><i class="fas fa-star"></i> Mes qualités professionnelles</h3>
                        <div class="section-content">
                            <p class="section-intro">Voici les qualités personnelles et professionnelles qui me caractérisent et que je mets au service de mes projets.</p>
                            
                            <div class="qualities-container">
                                <div class="quality-card">
                                    <div class="quality-icon">
                                        <i class="fas fa-lightbulb"></i>
                                    </div>
                                    <h4 class="quality-title">Résolution de problèmes</h4>
                                    <p class="quality-description">Capacité à analyser les situations complexes et à trouver des solutions efficaces, même sous pression.</p>
                                    <div class="quality-bar-container">
                                        <div class="quality-level">
                                            <span>Niveau</span>
                                            <span>85%</span>
                                        </div>
                                        <div class="quality-bar">
                                            <div class="quality-progress" data-progress="85"></div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="quality-card">
                                    <div class="quality-icon">
                                        <i class="fas fa-users"></i>
                                    </div>
                                    <h4 class="quality-title">Travail d'équipe</h4>
                                    <p class="quality-description">Aptitude à collaborer efficacement, partager des connaissances et contribuer à un environnement de travail positif.</p>
                                    <div class="quality-bar-container">
                                        <div class="quality-level">
                                            <span>Niveau</span>
                                            <span>90%</span>
                                        </div>
                                        <div class="quality-bar">
                                            <div class="quality-progress" data-progress="90"></div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="quality-card">
                                    <div class="quality-icon">
                                        <i class="fas fa-book-reader"></i>
                                    </div>
                                    <h4 class="quality-title">Apprentissage continu</h4>
                                    <p class="quality-description">Curiosité intellectuelle et volonté constante d'acquérir de nouvelles compétences et connaissances dans le domaine IT.</p>
                                    <div class="quality-bar-container">
                                        <div class="quality-level">
                                            <span>Niveau</span>
                                            <span>95%</span>
                                        </div>
                                        <div class="quality-bar">
                                            <div class="quality-progress" data-progress="95"></div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="quality-card">
                                    <div class="quality-icon">
                                        <i class="fas fa-clock"></i>
                                    </div>
                                    <h4 class="quality-title">Gestion du temps</h4>
                                    <p class="quality-description">Organisation efficace des tâches et respect des délais, même dans des projets complexes avec des contraintes temporelles.</p>
                                    <div class="quality-bar-container">
                                        <div class="quality-level">
                                            <span>Niveau</span>
                                            <span>80%</span>
                                        </div>
                                        <div class="quality-bar">
                                            <div class="quality-progress" data-progress="80"></div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="quality-card">
                                    <div class="quality-icon">
                                        <i class="fas fa-shield-alt"></i>
                                    </div>
                                    <h4 class="quality-title">Rigueur et méthodologie</h4>
                                    <p class="quality-description">Application systématique des bonnes pratiques et attention aux détails, particulièrement importante en sécurité informatique.</p>
                                    <div class="quality-bar-container">
                                        <div class="quality-level">
                                            <span>Niveau</span>
                                            <span>85%</span>
                                        </div>
                                        <div class="quality-bar">
                                            <div class="quality-progress" data-progress="85"></div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="quality-card">
                                    <div class="quality-icon">
                                        <i class="fas fa-comments"></i>
                                    </div>
                                    <h4 class="quality-title">Communication</h4>
                                    <p class="quality-description">Capacité à expliquer des concepts techniques complexes de manière claire et accessible à différents publics.</p>
                                    <div class="quality-bar-container">
                                        <div class="quality-level">
                                            <span>Niveau</span>
                                            <span>75%</span>
                                        </div>
                                        <div class="quality-bar">
                                            <div class="quality-progress" data-progress="75"></div>
                                        </div>
                                    </div>
                                </div>
