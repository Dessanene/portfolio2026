                                        <div class="skill-item">
                                            <span class="skill-name" data-level="70%">Authentification forte</span>
                                            <div class="skill-bar">
                                                <div class="skill-level" style="width: 70%"></div>
                                            </div>
                                        </div>
                                        <div class="skill-item">
                                            <span class="skill-name" data-level="70%">Sécurité réseau</span>
